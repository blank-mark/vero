rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function chatDoc(chatId) {
      return get(/databases/$(database)/documents/chats/$(chatId));
    }

    function isChatParticipant(chatId) {
      return signedIn()
        && exists(/databases/$(database)/documents/chats/$(chatId))
        && chatDoc(chatId).data.participants is list
        && chatDoc(chatId).data.participants.hasAny([request.auth.uid]);
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create, update, delete: if isSelf(uid);
    }

    match /chats/{chatId} {
      allow create: if signedIn()
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants;

      allow read, update, delete: if isChatParticipant(chatId);

      match /messages/{messageId} {
        allow read: if isChatParticipant(chatId);
        allow create: if isChatParticipant(chatId)
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isChatParticipant(chatId);
      }
    }

    match /calls/{callId} {
      allow create: if signedIn()
        && request.resource.data.callerId == request.auth.uid
        && request.resource.data.calleeId is string;

      allow read, update, delete: if signedIn()
        && (resource.data.callerId == request.auth.uid || resource.data.calleeId == request.auth.uid);

      match /callerCandidates/{candidateId} {
        allow read, create: if signedIn()
          && get(/databases/$(database)/documents/calls/$(callId)).data.callerId == request.auth.uid;
      }

      match /calleeCandidates/{candidateId} {
        allow read, create: if signedIn()
          && get(/databases/$(database)/documents/calls/$(callId)).data.calleeId == request.auth.uid;
      }
    }
  }
}